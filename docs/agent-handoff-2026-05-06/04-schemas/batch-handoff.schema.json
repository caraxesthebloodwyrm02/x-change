{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Batch Handoff",
  "type": "object",
  "required": ["batch_id", "goal", "source_docs", "inputs", "outputs", "allowed_actions", "forbidden_actions", "acceptance_criteria"],
  "properties": {
    "batch_id": { "type": "string" },
    "goal": { "type": "string" },
    "source_docs": { "type": "array", "items": { "type": "string" } },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "allowed_actions": { "type": "array", "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "parallel_safe_work": { "type": "array", "items": { "type": "string" } },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "likely_blockers": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

